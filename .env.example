# Монорепозиторий: можно использовать один .env в корне (backend читает ../.env из back/)
# Либо раздельные файлы: back/.env и front/.env — см. back/.env.example и front/.env.example

# --- Frontend (front/) ---
VITE_API_URL=https://role-control.ru/api
# VITE_BASE_PATH=/diplomNew/

# --- Backend (back/) ---
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/diplom
JWT_SECRET=change_me_min_16_chars
JWT_EXPIRES_IN=1d
CORS_ORIGIN=http://localhost:5173
