# Backend — модуль RBAC (скопируйте в back/.env или в корневой .env монорепозитория)

NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/diplom
JWT_SECRET=change_me_min_16_chars
JWT_EXPIRES_IN=1d

# Разрешённые origin для CORS (через запятую, если несколько фронтендов)
CORS_ORIGIN=http://localhost:5173
