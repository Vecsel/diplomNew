# Frontend — админ-панель модуля RBAC (скопируйте в front/.env)

# Базовый URL REST API модуля (обязательно, без завершающего слэша)
VITE_API_URL=http://localhost:4000/api

# Базовый путь SPA при размещении в подкаталоге (опционально; по умолчанию /)
# Пример для GitHub Pages: VITE_BASE_PATH=/diplomNew/
